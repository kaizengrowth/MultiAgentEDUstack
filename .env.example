# Copy to .env and fill in what you have. Every scout works without this
# file except reddit_scout.py and social_scout.py, which skip themselves
# cleanly (log a message, exit 0) when their credentials are absent.

# Reddit's API has required OAuth app credentials since 2023; unauthenticated
# .json endpoints now 403 from most IPs. Register a "script" app at
# https://www.reddit.com/prefs/apps to get these.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MultiAgentEDUstack/0.1 by yourusername

# X/Twitter's API requires a paid tier for any meaningful read access as of
# 2026. social_scout.py is a real adapter against the v2 API, but will not
# run without a bearer token here. Bluesky's AT Protocol is free/open and
# is the currently-implemented half of this scout.
X_BEARER_TOKEN=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional: only needed if you want richer YouTube metadata (view counts,
# channel subscriber counts) than yt-dlp's scrape-based extraction gives you.
# The transcript pipeline itself (youtube_scout.py) does not need this.
YOUTUBE_DATA_API_KEY=

# Only needed for the LLM-driven agents (agents/*/SKILL.md) if you're
# invoking them outside an already-authenticated Claude Code CLI (`claude
# login`). The systemd timer in this repo shells out to `claude -p` directly
# and reuses whatever login is already active for the user running it, so
# this is usually unnecessary.
ANTHROPIC_API_KEY=
